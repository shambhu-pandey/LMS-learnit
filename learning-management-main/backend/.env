# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/learning-management
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/learning-management
MONGO_URI=mongodb://localhost:27017/learning-management

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Other configurations can be added here as needed
